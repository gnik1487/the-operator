---
import '../styles/global.css';
export interface Props {
  num: string;
  title: string;
  description: string;
  section: string;
  wordCount?: number;
  urlSlug: string;
}
const { num, title, description, section, wordCount, urlSlug } = Astro.props;
const readMin = wordCount ? Math.round(wordCount / 200) : 9;
---
<a href={`/blog/${urlSlug}`} class="st-log-row">
  <span class="no">{num}</span>
  <span class="tt">{title}</span>
  <span class="sec">{section}</span>
  <span class="meta">{wordCount ? `${wordCount.toLocaleString()} w` : ''} · {readMin} min</span>
  <span class="stat live">Live</span>
</a>
