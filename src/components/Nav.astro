---
import '../styles/global.css';
const path = Astro.url.pathname;
---

<header class="nu-head">
  <div class="nu-head-inner">
    <a href="/" class="nu-brand">
      <svg class="nu-logo-mark" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="9.5" stroke="#44E5C0" stroke-width="1" opacity="0.38"/>
        <circle cx="11" cy="11" r="6.2" stroke="#44E5C0" stroke-width="1.3" opacity="0.72"/>
        <circle cx="11" cy="11" r="2.4" fill="#44E5C0"/>
      </svg>
      automation<b>/</b>diary
    </a>
    <nav class="nu-nav">
      <a href="/" class={path === '/' || path === '' ? 'on' : ''}>Live</a>
      <a href="/workflows" class={path.startsWith('/workflows') ? 'on' : ''}>Workflows</a>
      <a href="/tool-decisions" class={path.startsWith('/tool-decisions') ? 'on' : ''}>Tools</a>
      <a href="/systems" class={path.startsWith('/systems') ? 'on' : ''}>Systems</a>
      <a href="/field-outputs" class={path.startsWith('/field-outputs') ? 'on' : ''}>Field Outputs</a>
      <a href="/about" class={path === '/about' || path === '/about/' ? 'on' : ''}>About</a>
    </nav>
    <div class="nu-head-right">
      <span class="nu-live">
        <span class="dot"></span>
        running · briefing 012
      </span>
      <a href="#subscribe" class="nu-btn primary">Subscribe</a>
    </div>
  </div>
</header>
