---
import '../styles/global.css';
---
<div class="nu-sub" id="subscribe">
  <div class="nu-sub-inner">
    <div>
      <span class="e">▮ Signal · the newsletter</span>
      <h2>One real workflow, in your inbox, <em>when it's ready.</em></h2>
      <p>No schedule. No filler. No sponsored placements. A new build goes out only when it's worth your ten minutes.</p>
      <p class="quote">"I'll only send you something I would have written even if nobody paid me to. The day that stops — the newsletter stops."</p>
    </div>
    <div>
      <form class="nu-sub-form" action="#" method="post">
        <input type="email" name="email" placeholder="you@firm.com" required />
        <button type="submit" class="go">Subscribe →</button>
      </form>
      <div class="nu-sub-stats">
        <div><b>1,247</b><span>subscribers</span></div>
        <div><b>62%</b><span>open rate</span></div>
        <div><b>0</b><span>sponsored issues</span></div>
      </div>
    </div>
  </div>
</div>
