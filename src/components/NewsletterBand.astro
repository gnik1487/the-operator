---
import '../styles/global.css';
---
<section class="st-sub" id="subscribe">
  <div class="st-sub-inner">
    <div>
      <h2>One real workflow, in your inbox, <em>when it's ready.</em></h2>
      <p>No schedule. No filler. No sponsored placements. A new build goes out only when it's worth your ten minutes — usually every 2–4 weeks.</p>
      <p class="honest">"I'll only send you something I would have written even if nobody paid me to. The day that stops, the newsletter stops."</p>
    </div>
    <div>
      <form class="form" action="#" method="post">
        <div class="row">
          <span class="k">Email</span>
          <input type="email" name="email" placeholder="you@firm.com" required />
        </div>
        <div class="row">
          <span class="k">Role</span>
          <span>Consultant ▾</span>
        </div>
        <div class="row">
          <span class="k">Cadence</span>
          <span>Irregular · only when filed</span>
        </div>
        <button type="submit" class="submit">
          <span>Subscribe to Issue 013 →</span>
          <span>→</span>
        </button>
      </form>
      <div class="stats">
        <div><b>1,247</b>Subscribers</div>
        <div><b>62%</b>Open rate</div>
        <div><b>0</b>Sponsored issues</div>
      </div>
    </div>
  </div>
</section>
