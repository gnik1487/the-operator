---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import '../styles/global.css';

const ARTICLES = [
  { no: '01', section: 'Workflows',     sNum: '01', title: 'The research workflow that replaced my analyst',            words: 1800, mins: 9,  status: 'live',   slug: 'research-workflow-replaced-my-analyst' },
  { no: '02', section: 'Tool Decisions',sNum: '02', title: 'I tested 4 AI note systems for a year. I kept one.',       words: 2200, mins: 11, status: 'live',   slug: 'tested-4-ai-note-systems-kept-one' },
  { no: '03', section: 'Workflows',     sNum: '01', title: 'The meeting-notes-to-deliverable pipeline',                words: 1900, mins: 9,  status: 'queued', slug: '' },
  { no: '04', section: 'Systems',       sNum: '03', title: 'Why I stopped using AI for the part everyone uses it for', words: 1600, mins: 8,  status: 'live',   slug: 'stopped-using-ai-for-what-everyone-uses-it-for' },
  { no: '05', section: 'Tool Decisions',sNum: '02', title: 'My entire consulting AI stack — and what each costs me',   words: 2400, mins: 12, status: 'queued', slug: '' },
  { no: '06', section: 'Workflows',     sNum: '01', title: 'The proposal-drafting system that tripled my output',      words: 2000, mins: 10, status: 'queued', slug: '' },
  { no: '07', section: 'Tool Decisions',sNum: '02', title: 'How to pick a tool when every review is an affiliate ad',  words: 1800, mins: 9,  status: 'queued', slug: '' },
];

const TESTIMONIALS = [
  { q: "Finally, someone writing about AI tools who has actually had to put output in front of a client. The failure annotations alone are worth the price of the template.", a: 'Director, Mid-Market Consulting Firm', tag: 'verified buyer · PIT-001' },
  { q: "I've subscribed to a lot of AI newsletters. This is the only one I look forward to — because nothing in it has ever felt written to fill a quota.", a: 'Fractional COO', tag: 'subscriber since issue 003' },
  { q: "The line — automate gathering, never judgement — reframed how I use Claude for client deliverables. Three months later it's still the rule I quote in my own head.", a: 'Independent strategy consultant', tag: 'reader · Singapore' },
  { q: "Half of what gets called 'thought leadership' on LinkedIn is people summarising a free trial. This site is what the real thing looks like.", a: 'Partner, boutique systems-integration firm', tag: 'reader · London' },
];

const READBY_LINE = 'Read by consultants and operators at firms across the industry.';

const latestOutputs = (await getCollection('fieldOutputs'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const kindLabel: Record<string, string> = {
  'screenshot':   'Screenshot',
  'diagram':      'Diagram',
  'before-after': 'Before / After',
  'prompt-chain': 'Prompt Chain',
  'flowmap':      'Flow Map',
  'failure-log':  'Failure Log',
};

const TOPICS = [
  { tag: 'client-research', n: 4 },
  { tag: 'note-systems',    n: 3 },
  { tag: 'proposals',       n: 2 },
  { tag: 'judgement',       n: 5 },
  { tag: 'meeting-prep',    n: 3 },
  { tag: 'tool-cost',       n: 2 },
  { tag: 'failures',        n: 6 },
  { tag: 'second-brain',    n: 2 },
  { tag: 'disclosure',      n: 4 },
  { tag: 'enterprise-systems', n: 2 },
];
---
<BaseLayout title="automation/diary — AI automation, shown not sold">
  <Nav slot="header" />

  <main>
    <!-- HERO -->
    <section class="nu-hero">
      <div class="nu-wrap">
        <span class="nu-hero-tag">
          <span class="dot"></span>
          <span>Briefing 012 — <b>live</b></span>
        </span>

        <h1 class="nu-hero-h1">
          The systems I <em>actually run</em> — including the parts that <em>broke.</em>
        </h1>

        <div class="nu-hero-grid">
          <div>
            <p class="nu-hero-lede">
              AI workflows documented from inside a working consulting practice — <mark>not tool reviews from someone who opened a free trial yesterday.</mark> What survives past the novelty. What I cut. What a senior professional should actually copy.
            </p>
            <div class="nu-hero-cta">
              <a href="/blog/research-workflow-replaced-my-analyst" class="nu-btn primary">Read the latest →</a>
              <a href="/workflows" class="nu-btn ghost">Browse the archive</a>
            </div>
          </div>

          <!-- Neural network panel -->
          <div class="nu-brain">
            <div class="nu-brain-head">
              <span>▮ live · briefing engine</span>
              <span class="live">running</span>
            </div>
            <div class="nu-brain-viz">
              <svg viewBox="0 0 380 220" preserveAspectRatio="xMidYMid meet">
                <!-- edges layer 0→1 -->
                <line class="link active" x1="76" y1="55"  x2="152" y2="37"  />
                <line class="link"        x1="76" y1="55"  x2="152" y2="81"  />
                <line class="link active" x1="76" y1="55"  x2="152" y2="125" />
                <line class="link"        x1="76" y1="55"  x2="152" y2="169" />
                <line class="link active" x1="76" y1="55"  x2="152" y2="213" />
                <line class="link"        x1="76" y1="110" x2="152" y2="37"  />
                <line class="link active" x1="76" y1="110" x2="152" y2="81"  />
                <line class="link"        x1="76" y1="110" x2="152" y2="125" />
                <line class="link active" x1="76" y1="110" x2="152" y2="169" />
                <line class="link"        x1="76" y1="110" x2="152" y2="213" />
                <line class="link active" x1="76" y1="165" x2="152" y2="37"  />
                <line class="link"        x1="76" y1="165" x2="152" y2="81"  />
                <line class="link active" x1="76" y1="165" x2="152" y2="125" />
                <line class="link"        x1="76" y1="165" x2="152" y2="169" />
                <line class="link active" x1="76" y1="165" x2="152" y2="213" />
                <!-- edges layer 1→2 -->
                <line class="link"        x1="152" y1="37"  x2="228" y2="37"  />
                <line class="link active" x1="152" y1="37"  x2="228" y2="81"  />
                <line class="link"        x1="152" y1="37"  x2="228" y2="125" />
                <line class="link active" x1="152" y1="37"  x2="228" y2="169" />
                <line class="link"        x1="152" y1="37"  x2="228" y2="213" />
                <line class="link active" x1="152" y1="81"  x2="228" y2="37"  />
                <line class="link"        x1="152" y1="81"  x2="228" y2="81"  />
                <line class="link active" x1="152" y1="81"  x2="228" y2="125" />
                <line class="link"        x1="152" y1="125" x2="228" y2="81"  />
                <line class="link active" x1="152" y1="125" x2="228" y2="125" />
                <line class="link"        x1="152" y1="125" x2="228" y2="169" />
                <line class="link active" x1="152" y1="169" x2="228" y2="125" />
                <line class="link"        x1="152" y1="169" x2="228" y2="169" />
                <line class="link active" x1="152" y1="169" x2="228" y2="213" />
                <line class="link"        x1="152" y1="213" x2="228" y2="169" />
                <line class="link active" x1="152" y1="213" x2="228" y2="213" />
                <!-- edges layer 2→3 -->
                <line class="link active" x1="228" y1="37"  x2="304" y2="55"  />
                <line class="link"        x1="228" y1="81"  x2="304" y2="55"  />
                <line class="link active" x1="228" y1="81"  x2="304" y2="110" />
                <line class="link"        x1="228" y1="125" x2="304" y2="55"  />
                <line class="link active" x1="228" y1="125" x2="304" y2="110" />
                <line class="link"        x1="228" y1="125" x2="304" y2="165" />
                <line class="link active" x1="228" y1="169" x2="304" y2="110" />
                <line class="link"        x1="228" y1="169" x2="304" y2="165" />
                <line class="link active" x1="228" y1="213" x2="304" y2="165" />
                <!-- layer 0 nodes -->
                <circle class="node firing" cx="76"  cy="55"  r="4" style="animation-delay:0s"/>
                <circle class="node dim"    cx="76"  cy="110" r="2.5"/>
                <circle class="node firing" cx="76"  cy="165" r="4" style="animation-delay:.24s"/>
                <!-- layer 1 nodes -->
                <circle class="node dim"    cx="152" cy="37"  r="2.5"/>
                <circle class="node firing" cx="152" cy="81"  r="4" style="animation-delay:.08s"/>
                <circle class="node firing" cx="152" cy="125" r="4" style="animation-delay:.32s"/>
                <circle class="node dim"    cx="152" cy="169" r="2.5"/>
                <circle class="node firing" cx="152" cy="213" r="4" style="animation-delay:.56s"/>
                <!-- layer 2 nodes -->
                <circle class="node firing" cx="228" cy="37"  r="4" style="animation-delay:.16s"/>
                <circle class="node dim"    cx="228" cy="81"  r="2.5"/>
                <circle class="node firing" cx="228" cy="125" r="4" style="animation-delay:.40s"/>
                <circle class="node firing" cx="228" cy="169" r="4" style="animation-delay:.64s"/>
                <circle class="node dim"    cx="228" cy="213" r="2.5"/>
                <!-- layer 3 nodes -->
                <circle class="node dim"    cx="304" cy="55"  r="2.5"/>
                <circle class="node firing" cx="304" cy="110" r="4" style="animation-delay:.48s"/>
                <circle class="node firing" cx="304" cy="165" r="4" style="animation-delay:.72s"/>
              </svg>
            </div>
            <div class="nu-brain-stats">
              <div><b>3</b><span>stages</span></div>
              <div><b>2/3</b><span>automated</span></div>
              <div><b>40min</b><span>per file</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="nu-cue">
        <span>scroll</span>
        <span class="arrow"></span>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="nu-marquee">
      <span class="nu-marquee-lbl">{READBY_LINE}</span>
    </div>

    <div class="nu-wrap">

      <!-- METRICS -->
      <section class="nu-sect" style="padding-top:90px;padding-bottom:0">
        <div class="nu-metrics">
          <div class="nu-metric">
            <div class="ix"><span>METRIC.01</span><span style="color:var(--accent)">● live</span></div>
            <div class="n">18<sup>mo</sup></div>
            <div class="l">Minimum trial before a tool is written about</div>
          </div>
          <div class="nu-metric">
            <div class="ix"><span>METRIC.02</span><span style="color:var(--accent)">● live</span></div>
            <div class="n">40<sup>min</sup></div>
            <div class="l">From prep to point of view</div>
          </div>
          <div class="nu-metric">
            <div class="ix"><span>METRIC.03</span><span style="color:var(--accent)">● live</span></div>
            <div class="n">83<sup>%</sup></div>
            <div class="l">Time saved per research session</div>
          </div>
          <div class="nu-metric">
            <div class="ix"><span>METRIC.04</span><span style="color:var(--accent)">● live</span></div>
            <div class="n">0</div>
            <div class="l">Affiliate posts without disclosure</div>
          </div>
        </div>
      </section>

      <!-- PIPELINE -->
      <section class="nu-sect">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ The pattern · every file on this site</span>
            <h2><em>Machine proposes.</em><br/>Human disposes.</h2>
          </div>
          <div class="r">▮ three stages<br/>▮ two automated<br/>▮ one never will be</div>
        </div>
        <div class="nu-pipeline">
          <div class="nu-stage">
            <div class="n">01</div>
            <h4>Gather <em>·</em></h4>
            <div class="stage-meta"><b>AUTO</b> · ≈ 5 min · by hand curation</div>
            <p>Plain markdown. One vault. Quality of input sets the ceiling — five minutes of human curation beats any amount of automated collection.</p>
            <div class="out">
              <span class="a">→</span> 1 structured note<br/>
              <span class="a">→</span> 3 industry sources<br/>
              <span class="a">→</span> 1 reusable template
            </div>
          </div>
          <div class="nu-stage">
            <div class="n">02</div>
            <h4>Compress <em>·</em></h4>
            <div class="stage-meta"><b>AUTO</b> · ≈ 2 min · by Claude</div>
            <p>Contrast, not summary. The prompt asks for three strategic tensions, not a paragraph. Tension is where the meeting lives.</p>
            <div class="out">
              <span class="a">→</span> 3 strategic tensions<br/>
              <span class="a">→</span> evidence per tension<br/>
              <span class="a">→</span> the avoided question
            </div>
          </div>
          <div class="nu-stage manual">
            <div class="n">03</div>
            <h4>Provoke <em>·</em></h4>
            <div class="stage-meta"><b>HUMAN</b> · ≈ 30 min · by you</div>
            <p>Argue with each tension. Discard one on purpose. Form one point of view sharp enough to be wrong in an interesting way.</p>
            <div class="out">
              <span class="m">→</span> 1 lead point of view<br/>
              <span class="m">→</span> 1 deliberately discarded<br/>
              <span class="m">→</span> a note that compounds
            </div>
          </div>
        </div>
      </section>

      <!-- FEATURE -->
      <section class="nu-sect" style="padding-top:40px">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ This week · cover briefing</span>
            <h2>The research workflow that <em>replaced my analyst</em>.</h2>
          </div>
          <div class="r">▮ live<br/>▮ rev.04 · 1,800 w<br/>▮ 9 min read</div>
        </div>
        <div class="nu-feature">
          <div class="nu-feature-l">
            <span class="pill">▮ §01 · workflows · file 01</span>
            <h3>Forty minutes, a real point of view at the end of it.</h3>
            <p>Half a day of client prep, cut to forty minutes — and the forty minutes are better. The exact Claude + Obsidian pipeline, including the two steps I had to throw away.</p>
            <div class="feat-meta">
              <div><b>40m</b>runtime</div>
              <div><b>3</b>stages</div>
              <div><b>2</b>failures kept</div>
              <div><b>$29</b>template</div>
            </div>
            <div class="feat-btns">
              <a href="/blog/research-workflow-replaced-my-analyst" class="nu-btn primary">Read briefing 01 →</a>
              <a href="#" class="nu-btn ghost">Get the $29 template</a>
            </div>
          </div>
          <div class="nu-feature-r">
            <div>
              <span class="c">// the workflow this site is built around</span><br/>
              <span class="prompt">$</span> intake <span class="a">--prospect "acme-co"</span><br/>
              <span class="c">&nbsp;&nbsp;✓ structured · 4.2s</span><br/>
              <span class="prompt">$</span> compress <span class="a">--mode tension --n 3</span><br/>
              <span class="c">&nbsp;&nbsp;✓ 3 tensions · 18s</span><br/>
              <span class="prompt">$</span> provoke <span class="c"># human · always</span><br/>
              <span class="c">&nbsp;&nbsp;</span><span class="a">▮</span> tension A · real or obvious?<br/>
              <span class="c">&nbsp;&nbsp;</span><span class="a">▮</span> tension B · would-be-wrong-if?<br/>
              <span class="c">&nbsp;&nbsp;</span><span class="a">▮</span> tension C · cut on purpose<br/>
              <br/>
              <span class="c">// total · 40min · was 4hr · saving 83%</span><br/>
              <span class="prompt">$</span> <span class="w">deliver --view "the one that matters"</span><span class="nu-cur"></span>
            </div>
          </div>
        </div>
      </section>

      <!-- FILING LOG -->
      <section class="nu-sect" style="padding-top:40px">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ The archive · 7 files</span>
            <h2>Every <em>system</em>, filed.</h2>
          </div>
          <div class="r">▮ 3 live · 4 queued</div>
        </div>
        <div class="nu-log">
          <div class="nu-log-head">
            <span class="l">▮ /diary/files — live</span>
            <span>sorted by · latest filed</span>
            <span>3 live · 4 queued</span>
          </div>
          {ARTICLES.map(a => (
            a.status === 'live' ? (
              <a href={`/blog/${a.slug}`} class="nu-log-row">
                <span class="no">№ {a.no}</span>
                <span class="tt">{a.title}</span>
                <span class="sec">§{a.sNum} · {a.section}</span>
                <span class="meta">{a.words.toLocaleString()} w · {a.mins}m</span>
                <span class="stat"><span class="pill live"><span class="dot"></span>Live</span></span>
              </a>
            ) : (
              <div class="nu-log-row">
                <span class="no">№ {a.no}</span>
                <span class="tt">{a.title}</span>
                <span class="sec">§{a.sNum} · {a.section}</span>
                <span class="meta">{a.words.toLocaleString()} w · {a.mins}m</span>
                <span class="stat"><span class="pill queued"><span class="dot"></span>Queued</span></span>
              </div>
            )
          ))}
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section class="nu-sect" style="padding-top:40px">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ Field reports</span>
            <h2>What readers <em>actually say</em>.</h2>
          </div>
          <div class="r">▮ unsolicited · printed with permission</div>
        </div>
        <div class="nu-quotes">
          {TESTIMONIALS.map(q => (
            <div class="nu-quote">
              <p>{q.q}</p>
              <div class="att"><span><b>{q.a}</b></span><span>{q.tag}</span></div>
            </div>
          ))}
        </div>
      </section>

      <!-- TOPICS -->
      <section class="nu-sect" style="padding-top:40px">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ Threads · 10 active</span>
            <h2>Browse by <em>topic</em>.</h2>
          </div>
          <div class="r">▮ click any chip</div>
        </div>
        <div class="nu-topics">
          {TOPICS.map(t => (
            <span class="nu-chip">
              <span class="hash">#</span>{t.tag}<span class="n">{t.n}</span>
            </span>
          ))}
        </div>
      </section>

      <!-- AUTHOR -->
      <section class="nu-sect" style="padding-top:40px">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ The Operator</span>
            <h2>Filed from inside <em>real work.</em></h2>
          </div>
          <div class="r">▮ no ghost-writers, ever<br/>▮ no demos · only what runs</div>
        </div>
        <div class="nu-author">
          <div class="nu-author-img">
            <span class="stamp">▮ THE OPERATOR</span>
            <span class="glyph">AD</span>
          </div>
          <div class="nu-author-body">
            <span class="e">▮ About the archive</span>
            <h2>The work here had to survive <em>real deadlines, real clients, real consequences.</em></h2>
            <p>A highly experienced practitioner in enterprise systems and AI workflows — working at the intersection of complex client engagements and automation tooling. Not a full-time creator; someone with actual skin in the game.</p>
            <p>I think about AI tools the way I think about any operational platform: not "is it impressive in a demo," but "does it still earn its place eighteen months in, when the novelty's gone."</p>
            <div class="creds">
              <div class="cred"><div class="k">Voice</div><div class="v">First-person practitioner</div></div>
              <div class="cred"><div class="k">Standard</div><div class="v">Only what is actually run</div></div>
              <div class="cred"><div class="k">Failures</div><div class="v">Always included</div></div>
              <div class="cred"><div class="k">Affiliates</div><div class="v">Disclosed every time</div></div>
            </div>
          </div>
        </div>
      </section>

      <!-- FIELD OUTPUTS STRIP -->
      <section class="nu-sect">
        <div class="nu-sect-head">
          <div>
            <span class="e">▮ §04 Field Outputs · latest from the workbench</span>
            <h2>The work, <em>shown directly.</em></h2>
          </div>
          <div class="r"><a href="/field-outputs" style="color:var(--accent);font-family:var(--font-mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none">View all →</a></div>
        </div>
        <div class="nu-dept-grid">
          {latestOutputs.map(a => (
            <a href={`/field-outputs/${a.data.urlSlug}`} class="nu-dept-card" style="text-decoration:none">
              <div class="num">{kindLabel[a.data.kind] ?? a.data.kind}</div>
              <h3>{a.data.title}</h3>
              <p>{a.data.summary}</p>
              <span class="dept-link">View artifact →</span>
            </a>
          ))}
        </div>
      </section>

    </div>
  </main>

  <div class="nu-wrap" style="padding-bottom:90px">
    <NewsletterBand />
  </div>
  <Footer slot="footer" />
</BaseLayout>
