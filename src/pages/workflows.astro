---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import ArticleCard from '../components/ArticleCard.astro';
import '../styles/global.css';

const articles = (await getCollection('blog', e => e.data.section === 'Workflows'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<BaseLayout title="Workflows — The Operator" description="End-to-end AI automations from a working consulting practice — step by step, failures included.">
  <Nav slot="header" />
  <div class="wrap rel">
    <div class="section-head">
      <div class="eyebrow">Section 01</div>
      <h2 class="serif">Workflows — the systems I <em>actually run</em></h2>
      <p>Each one is a real automation from my own practice. If a step broke, it's in here. If I still do part of it by hand, that's in here too.</p>
    </div>
  </div>
  <div class="cards rel">
    {articles.map((a, i) => (
      <ArticleCard
        num={`No. 0${i + 1}`}
        title={a.data.title}
        description={a.data.meta_description ?? ''}
        section={a.data.section}
        wordCount={a.data.word_count_target}
        urlSlug={a.data.urlSlug}
      />
    ))}
  </div>
  <NewsletterBand />
  <Footer slot="footer" />
</BaseLayout>
