---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import ArticleCard from '../components/ArticleCard.astro';
import '../styles/global.css';

const articles = (await getCollection('blog', e => e.data.section === 'Tool Decisions'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<BaseLayout
  title="Tool Decisions — automation/diary"
  description="Frameworks for choosing AI tools — decided by living with them for a year, not an afternoon."
>
  <Nav slot="header" />

  <div class="wrap">
    <div class="section-page-header">
      <div class="crumb">§02 · Tool Decisions</div>
      <h1>Frameworks, <em>not listicles</em></h1>
      <p class="strap">Anyone can list ten tools. The hard part is choosing when they all look the same. These are the decision frameworks I'd hand my past self.</p>
    </div>

    <div class="st-log">
      <div class="st-log-head">
        <span>№</span>
        <span>TITLE</span>
        <span>DEPARTMENT</span>
        <span>EXTENT</span>
        <span>STATUS</span>
      </div>
      {articles.map((a, i) => (
        <ArticleCard
          num={`0${i + 1}`}
          title={a.data.title}
          description={a.data.meta_description ?? ''}
          section={a.data.section}
          wordCount={a.data.word_count_target}
          urlSlug={a.data.urlSlug}
        />
      ))}
    </div>
  </div>

  <NewsletterBand />
  <Footer slot="footer" />
</BaseLayout>
